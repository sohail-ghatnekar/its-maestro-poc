<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/" id="definitions_IESCLIBuild_Intake_Rules" name="IESCLIBuild Intake Rules" namespace="http://uipath.com/iesclibuild/dmn/intake-rules" exporter="ChatGPT" exporterVersion="1.0">
  <inputData id="input_documentAvailable" name="documentAvailable">
    <variable id="var_documentAvailable" name="documentAvailable" typeRef="boolean"/>
  </inputData>
  <inputData id="input_myBNumberPresent" name="myBNumberPresent">
    <variable id="var_myBNumberPresent" name="myBNumberPresent" typeRef="boolean"/>
  </inputData>
  <inputData id="input_namePresent" name="namePresent">
    <variable id="var_namePresent" name="namePresent" typeRef="boolean"/>
  </inputData>
  <inputData id="input_addressPresent" name="addressPresent">
    <variable id="var_addressPresent" name="addressPresent" typeRef="boolean"/>
  </inputData>
  <inputData id="input_noFixedAddressFlag" name="noFixedAddressFlag">
    <variable id="var_noFixedAddressFlag" name="noFixedAddressFlag" typeRef="boolean"/>
  </inputData>
  <inputData id="input_signaturePresent" name="signaturePresent">
    <variable id="var_signaturePresent" name="signaturePresent" typeRef="boolean"/>
  </inputData>
  <inputData id="input_signatureDatePresent" name="signatureDatePresent">
    <variable id="var_signatureDatePresent" name="signatureDatePresent" typeRef="boolean"/>
  </inputData>
  <inputData id="input_countyKnown" name="countyKnown">
    <variable id="var_countyKnown" name="countyKnown" typeRef="boolean"/>
  </inputData>
  <inputData id="input_snapProgramSelected" name="snapProgramSelected">
    <variable id="var_snapProgramSelected" name="snapProgramSelected" typeRef="boolean"/>
  </inputData>
  <inputData id="input_applicantEmailPresent" name="applicantEmailPresent">
    <variable id="var_applicantEmailPresent" name="applicantEmailPresent" typeRef="boolean"/>
  </inputData>
  <decision id="decision_intake_rules" name="Intake Rules">
    <informationRequirement id="informationRequirement_documentAvailable">
      <requiredInput href="#input_documentAvailable"/>
    </informationRequirement>
    <informationRequirement id="informationRequirement_myBNumberPresent">
      <requiredInput href="#input_myBNumberPresent"/>
    </informationRequirement>
    <informationRequirement id="informationRequirement_namePresent">
      <requiredInput href="#input_namePresent"/>
    </informationRequirement>
    <informationRequirement id="informationRequirement_addressPresent">
      <requiredInput href="#input_addressPresent"/>
    </informationRequirement>
    <informationRequirement id="informationRequirement_noFixedAddressFlag">
      <requiredInput href="#input_noFixedAddressFlag"/>
    </informationRequirement>
    <informationRequirement id="informationRequirement_signaturePresent">
      <requiredInput href="#input_signaturePresent"/>
    </informationRequirement>
    <informationRequirement id="informationRequirement_signatureDatePresent">
      <requiredInput href="#input_signatureDatePresent"/>
    </informationRequirement>
    <informationRequirement id="informationRequirement_countyKnown">
      <requiredInput href="#input_countyKnown"/>
    </informationRequirement>
    <informationRequirement id="informationRequirement_snapProgramSelected">
      <requiredInput href="#input_snapProgramSelected"/>
    </informationRequirement>
    <informationRequirement id="informationRequirement_applicantEmailPresent">
      <requiredInput href="#input_applicantEmailPresent"/>
    </informationRequirement>
    <variable id="decisionVariable_intake_rules" name="intakeDecision" typeRef="string"/>
    <decisionTable id="decisionTable_intake_rules" hitPolicy="FIRST">
      <input id="inputClause_documentAvailable" label="Document available">
        <inputExpression id="inputExpr_documentAvailable" typeRef="boolean">
          <text>documentAvailable</text>
        </inputExpression>
      </input>
      <input id="inputClause_myBNumberPresent" label="MyB number present">
        <inputExpression id="inputExpr_myBNumberPresent" typeRef="boolean">
          <text>myBNumberPresent</text>
        </inputExpression>
      </input>
      <input id="inputClause_namePresent" label="Applicant name present">
        <inputExpression id="inputExpr_namePresent" typeRef="boolean">
          <text>namePresent</text>
        </inputExpression>
      </input>
      <input id="inputClause_addressPresent" label="Residence address present">
        <inputExpression id="inputExpr_addressPresent" typeRef="boolean">
          <text>addressPresent</text>
        </inputExpression>
      </input>
      <input id="inputClause_noFixedAddressFlag" label="No fixed address flag">
        <inputExpression id="inputExpr_noFixedAddressFlag" typeRef="boolean">
          <text>noFixedAddressFlag</text>
        </inputExpression>
      </input>
      <input id="inputClause_signaturePresent" label="Signature present">
        <inputExpression id="inputExpr_signaturePresent" typeRef="boolean">
          <text>signaturePresent</text>
        </inputExpression>
      </input>
      <input id="inputClause_signatureDatePresent" label="Signature date present">
        <inputExpression id="inputExpr_signatureDatePresent" typeRef="boolean">
          <text>signatureDatePresent</text>
        </inputExpression>
      </input>
      <input id="inputClause_countyKnown" label="County known">
        <inputExpression id="inputExpr_countyKnown" typeRef="boolean">
          <text>countyKnown</text>
        </inputExpression>
      </input>
      <input id="inputClause_snapProgramSelected" label="SNAP selected">
        <inputExpression id="inputExpr_snapProgramSelected" typeRef="boolean">
          <text>snapProgramSelected</text>
        </inputExpression>
      </input>
      <input id="inputClause_applicantEmailPresent" label="Applicant email present">
        <inputExpression id="inputExpr_applicantEmailPresent" typeRef="boolean">
          <text>applicantEmailPresent</text>
        </inputExpression>
      </input>
      <output id="output_intakeDecision" name="intakeDecision" typeRef="string"/>
      <rule id="intake_rule_001_document_missing">
        <description>No application document pointer was supplied to the extraction flow.</description>
        <inputEntry id="intake_r001_i1">
          <text>false</text>
        </inputEntry>
        <inputEntry id="intake_r001_i2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r001_i3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r001_i4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r001_i5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r001_i6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r001_i7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r001_i8">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r001_i9">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r001_i10">
          <text>-</text>
        </inputEntry>
        <outputEntry id="intake_r001_o1">
          <text>"INTAKE_DOCUMENT_MISSING"</text>
        </outputEntry>
      </rule>
      <rule id="intake_rule_002_myb_missing">
        <description>MyB number is required for case tracking and worker inbox display.</description>
        <inputEntry id="intake_r002_i1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r002_i2">
          <text>false</text>
        </inputEntry>
        <inputEntry id="intake_r002_i3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r002_i4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r002_i5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r002_i6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r002_i7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r002_i8">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r002_i9">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r002_i10">
          <text>-</text>
        </inputEntry>
        <outputEntry id="intake_r002_o1">
          <text>"INTAKE_MYB_MISSING"</text>
        </outputEntry>
      </rule>
      <rule id="intake_rule_003_name_missing">
        <description>A SNAP filing cannot be accepted unless applicant name is present.</description>
        <inputEntry id="intake_r003_i1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r003_i2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r003_i3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="intake_r003_i4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r003_i5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r003_i6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r003_i7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r003_i8">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r003_i9">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r003_i10">
          <text>-</text>
        </inputEntry>
        <outputEntry id="intake_r003_o1">
          <text>"PEND_NAME"</text>
        </outputEntry>
      </rule>
      <rule id="intake_rule_004_signature_missing">
        <description>A SNAP filing cannot be accepted unless applicant or authorized representative signature is present.</description>
        <inputEntry id="intake_r004_i1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r004_i2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r004_i3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r004_i4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r004_i5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r004_i6">
          <text>false</text>
        </inputEntry>
        <inputEntry id="intake_r004_i7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r004_i8">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r004_i9">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r004_i10">
          <text>-</text>
        </inputEntry>
        <outputEntry id="intake_r004_o1">
          <text>"PEND_SIGNATURE"</text>
        </outputEntry>
      </rule>
      <rule id="intake_rule_005_address_missing">
        <description>Address is required for filing if the household has one; no fixed address flag can satisfy the address condition.</description>
        <inputEntry id="intake_r005_i1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r005_i2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r005_i3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r005_i4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="intake_r005_i5">
          <text>false</text>
        </inputEntry>
        <inputEntry id="intake_r005_i6">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r005_i7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r005_i8">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r005_i9">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r005_i10">
          <text>-</text>
        </inputEntry>
        <outputEntry id="intake_r005_o1">
          <text>"PEND_ADDRESS"</text>
        </outputEntry>
      </rule>
      <rule id="intake_rule_006_program_scope">
        <description>POC flow is SNAP-only; non-SNAP selections require worker routing review.</description>
        <inputEntry id="intake_r006_i1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r006_i2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r006_i3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r006_i4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r006_i5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r006_i6">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r006_i7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r006_i8">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r006_i9">
          <text>false</text>
        </inputEntry>
        <inputEntry id="intake_r006_i10">
          <text>-</text>
        </inputEntry>
        <outputEntry id="intake_r006_o1">
          <text>"PROGRAM_SCOPE_REVIEW"</text>
        </outputEntry>
      </rule>
      <rule id="intake_rule_007_county_unknown">
        <description>Minimum filing can be accepted, but missing county prevents automated group assignment.</description>
        <inputEntry id="intake_r007_i1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r007_i2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r007_i3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r007_i4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r007_i5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r007_i6">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r007_i7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r007_i8">
          <text>false</text>
        </inputEntry>
        <inputEntry id="intake_r007_i9">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r007_i10">
          <text>-</text>
        </inputEntry>
        <outputEntry id="intake_r007_o1">
          <text>"COUNTY_TRIAGE_REQUIRED"</text>
        </outputEntry>
      </rule>
      <rule id="intake_rule_008_signature_date_review">
        <description>Signature exists but signature date is missing or unreadable; worker review is required.</description>
        <inputEntry id="intake_r008_i1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r008_i2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r008_i3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r008_i4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r008_i5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r008_i6">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r008_i7">
          <text>false</text>
        </inputEntry>
        <inputEntry id="intake_r008_i8">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r008_i9">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r008_i10">
          <text>-</text>
        </inputEntry>
        <outputEntry id="intake_r008_o1">
          <text>"SIGNATURE_DATE_REVIEW"</text>
        </outputEntry>
      </rule>
      <rule id="intake_rule_009_contact_review">
        <description>Email is not a SNAP filing requirement, but the POC uses email for applicant outreach.</description>
        <inputEntry id="intake_r009_i1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r009_i2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r009_i3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r009_i4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r009_i5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r009_i6">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r009_i7">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r009_i8">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r009_i9">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r009_i10">
          <text>false</text>
        </inputEntry>
        <outputEntry id="intake_r009_o1">
          <text>"CONTACT_REVIEW_REQUIRED"</text>
        </outputEntry>
      </rule>
      <rule id="intake_rule_010_filing_accepted">
        <description>Minimum filing conditions are satisfied; proceed to expedited screening.</description>
        <inputEntry id="intake_r010_i1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r010_i2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r010_i3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r010_i4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r010_i5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="intake_r010_i6">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r010_i7">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r010_i8">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r010_i9">
          <text>true</text>
        </inputEntry>
        <inputEntry id="intake_r010_i10">
          <text>true</text>
        </inputEntry>
        <outputEntry id="intake_r010_o1">
          <text>"FILING_ACCEPTED"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_IESCLIBuild_Intake_Rules" name="IESCLIBuild Intake Rules Diagram">
      <dmndi:DMNPlane id="DMNPlane_IESCLIBuild_Intake_Rules" dmnElementRef="decision_intake_rules">
        <dmndi:DMNShape id="DMNShape_decision_intake_rules" dmnElementRef="decision_intake_rules">
          <dc:Bounds x="420" y="180" width="240" height="90"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_documentAvailable" dmnElementRef="input_documentAvailable">
          <dc:Bounds x="40" y="40" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_myBNumberPresent" dmnElementRef="input_myBNumberPresent">
          <dc:Bounds x="40" y="115" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_namePresent" dmnElementRef="input_namePresent">
          <dc:Bounds x="40" y="190" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_addressPresent" dmnElementRef="input_addressPresent">
          <dc:Bounds x="40" y="265" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_signaturePresent" dmnElementRef="input_signaturePresent">
          <dc:Bounds x="40" y="340" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_noFixedAddressFlag" dmnElementRef="input_noFixedAddressFlag">
          <dc:Bounds x="40" y="415" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_signatureDatePresent" dmnElementRef="input_signatureDatePresent">
          <dc:Bounds x="40" y="490" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_countyKnown" dmnElementRef="input_countyKnown">
          <dc:Bounds x="40" y="565" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_snapProgramSelected" dmnElementRef="input_snapProgramSelected">
          <dc:Bounds x="40" y="640" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNShape id="DMNShape_input_applicantEmailPresent" dmnElementRef="input_applicantEmailPresent">
          <dc:Bounds x="40" y="715" width="180" height="60"/>
        </dmndi:DMNShape>
        <dmndi:DMNEdge id="DMNEdge_input_documentAvailable" dmnElementRef="informationRequirement_documentAvailable">
          <di:waypoint x="220" y="70"/>
          <di:waypoint x="420" y="70"/>
        </dmndi:DMNEdge>
        <dmndi:DMNEdge id="DMNEdge_input_myBNumberPresent" dmnElementRef="informationRequirement_myBNumberPresent">
          <di:waypoint x="220" y="145"/>
          <di:waypoint x="420" y="145"/>
        </dmndi:DMNEdge>
        <dmndi:DMNEdge id="DMNEdge_input_namePresent" dmnElementRef="informationRequirement_namePresent">
          <di:waypoint x="220" y="220"/>
          <di:waypoint x="420" y="220"/>
        </dmndi:DMNEdge>
        <dmndi:DMNEdge id="DMNEdge_input_addressPresent" dmnElementRef="informationRequirement_addressPresent">
          <di:waypoint x="220" y="295"/>
          <di:waypoint x="420" y="295"/>
        </dmndi:DMNEdge>
        <dmndi:DMNEdge id="DMNEdge_input_signaturePresent" dmnElementRef="informationRequirement_signaturePresent">
          <di:waypoint x="220" y="370"/>
          <di:waypoint x="420" y="370"/>
        </dmndi:DMNEdge>
        <dmndi:DMNEdge id="DMNEdge_input_noFixedAddressFlag" dmnElementRef="informationRequirement_noFixedAddressFlag">
          <di:waypoint x="220" y="445"/>
          <di:waypoint x="420" y="445"/>
        </dmndi:DMNEdge>
        <dmndi:DMNEdge id="DMNEdge_input_signatureDatePresent" dmnElementRef="informationRequirement_signatureDatePresent">
          <di:waypoint x="220" y="520"/>
          <di:waypoint x="420" y="520"/>
        </dmndi:DMNEdge>
        <dmndi:DMNEdge id="DMNEdge_input_countyKnown" dmnElementRef="informationRequirement_countyKnown">
          <di:waypoint x="220" y="595"/>
          <di:waypoint x="420" y="595"/>
        </dmndi:DMNEdge>
        <dmndi:DMNEdge id="DMNEdge_input_snapProgramSelected" dmnElementRef="informationRequirement_snapProgramSelected">
          <di:waypoint x="220" y="670"/>
          <di:waypoint x="420" y="670"/>
        </dmndi:DMNEdge>
        <dmndi:DMNEdge id="DMNEdge_input_applicantEmailPresent" dmnElementRef="informationRequirement_applicantEmailPresent">
          <di:waypoint x="220" y="745"/>
          <di:waypoint x="420" y="745"/>
        </dmndi:DMNEdge>
      </dmndi:DMNPlane>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

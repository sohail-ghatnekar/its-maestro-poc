{
  "name": "iesclibuild-finalcaseworkerreview-actionapp",
  "version": "1.0.0",
  "private": true,
  "description": "UiPath Coded Action App for NY SNAP final case worker review.",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
